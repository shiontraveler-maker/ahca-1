<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AHCA — Approved Tax Agent | UAE Federal Tax Authority</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;color:#1a1a1a;background:#fff;overflow-x:hidden}

@keyframes fadeUp{from{opacity:0;transform:translateY(32px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeLeft{from{opacity:0;transform:translateX(-40px)}to{opacity:1;transform:translateX(0)}}
@keyframes fadeRight{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:translateX(0)}}
@keyframes scaleUp{from{opacity:0;transform:scale(0.88)}to{opacity:1;transform:scale(1)}}
@keyframes floatY{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.4}}
@keyframes barGrow{from{width:0}to{width:var(--w)}}
@keyframes rotateSlow{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}
@keyframes waBounce{0%,100%{transform:scale(1)}50%{transform:scale(1.1)}}
@keyframes popIn{0%{opacity:0;transform:scale(0.5) rotate(-10deg)}70%{transform:scale(1.08) rotate(2deg)}100%{opacity:1;transform:scale(1) rotate(0)}}
@keyframes slideIn{from{opacity:0;transform:translateY(40px)}to{opacity:1;transform:translateY(0)}}

:root{
  --e-deep:#011A10;--e-dark:#014D2E;--e-mid:#016B3F;--e-base:#018F54;
  --e-bright:#02B36A;--e-light:#5ECFA0;--e-pale:#AEE8CC;--e-wash:#E0F5EC;
  --gold:#C9A84C;--gold-light:#FFF8E7;--gold-dark:#8B6914;
}

/* SCROLL REVEAL */
.reveal{opacity:0;transform:translateY(44px);transition:opacity .7s ease,transform .7s ease}
.reveal.from-left{transform:translateX(-44px)}
.reveal.from-right{transform:translateX(44px)}
.reveal.scale{transform:scale(0.88);opacity:0}
.reveal.visible{opacity:1;transform:none}

/* TOP BAR */
.topbar{background:var(--e-deep);color:var(--e-pale);font-size:12px;text-align:center;padding:9px 2rem;display:flex;align-items:center;justify-content:center;gap:8px}
.topbar-dot{width:6px;height:6px;border-radius:50%;background:#25D366;animation:pulse 1.5s infinite;flex-shrink:0}

/* NAV */
nav{display:flex;justify-content:space-between;align-items:center;padding:.9rem 2rem;border-bottom:1px solid rgba(1,143,84,0.15);background:#fff;position:sticky;top:0;z-index:200}
.logo{font-family:'Syne',sans-serif;font-size:24px;font-weight:800;letter-spacing:-0.02em;color:#1a1a1a;display:flex;align-items:center;gap:4px}
.logo-badge{background:var(--e-base);color:#fff;font-size:9px;font-weight:700;padding:2px 7px;border-radius:6px;margin-left:4px;letter-spacing:.05em;vertical-align:3px}
.nlinks{display:flex;gap:1.5rem}
.nlinks a{font-size:13px;color:#555;text-decoration:none;cursor:pointer;transition:color .2s}
.nlinks a:hover{color:var(--e-base)}
.nav-right{display:flex;align-items:center;gap:8px}
.wa-nav{background:#25D366;color:#fff;border:none;padding:7px 14px;border-radius:20px;font-size:12px;font-family:'Inter',sans-serif;cursor:pointer;display:flex;align-items:center;gap:5px;transition:transform .2s}
.wa-nav:hover{transform:scale(1.05)}
.ncta{background:var(--e-base);color:#fff;border:none;padding:8px 20px;border-radius:20px;font-size:13px;font-family:'Inter',sans-serif;cursor:pointer;transition:transform .2s,background .2s}
.ncta:hover{transform:scale(1.05);background:var(--e-mid)}

/* HERO */
.hero{min-height:88vh;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:4rem 2rem 3rem;position:relative;overflow:hidden;background:#fff}
.hero-orbit{position:absolute;border-radius:50%;border:0.5px solid rgba(1,143,84,0.12);pointer-events:none}
.orb1{width:500px;height:500px;top:-140px;right:-130px;animation:rotateSlow 40s linear infinite}
.orb2{width:300px;height:300px;bottom:-100px;left:-80px;animation:rotateSlow 28s linear infinite reverse}
.orb3{width:180px;height:180px;top:60px;left:40px;animation:rotateSlow 20s linear infinite;opacity:.5}

.cert-hero-badge{display:inline-flex;align-items:center;gap:8px;background:#E8F0FE;color:#1a3a8f;border:1px solid #93a8f4;font-size:13px;font-weight:700;padding:9px 22px;border-radius:28px;margin-bottom:1.6rem;animation:popIn 0.7s 0.1s both;letter-spacing:.01em}
.hero h1{font-family:'Syne',sans-serif;font-size:52px;font-weight:800;line-height:1.08;margin-bottom:.8rem;letter-spacing:-0.03em;animation:fadeUp 0.7s 0.2s both}
.hero h1 em{font-style:normal;color:var(--e-base);display:inline-block;animation:floatY 3.5s ease-in-out infinite}
.hero-tagline{font-family:'Syne',sans-serif;font-size:17px;font-weight:600;color:var(--e-mid);margin-bottom:1rem;animation:fadeUp 0.6s 0.35s both;display:flex;align-items:center;justify-content:center;gap:8px}
.hero-sub{font-size:16px;color:#555;max-width:500px;margin:0 auto 1.8rem;line-height:1.7;animation:fadeUp 0.6s 0.45s both}

.hero-promise{display:flex;gap:10px;justify-content:center;flex-wrap:wrap;margin-bottom:2.2rem;animation:fadeUp 0.5s 0.55s both}
.promise-pill{background:var(--e-wash);color:var(--e-dark);font-size:12px;font-weight:600;padding:6px 14px;border-radius:20px;border:0.5px solid rgba(1,143,84,0.2);display:flex;align-items:center;gap:5px}
.pill-check{color:var(--e-base)}

.hero-btns{display:flex;gap:12px;justify-content:center;flex-wrap:wrap;animation:fadeUp 0.6s 0.62s both}
.btn-p{background:var(--e-base);color:#fff;border:none;padding:13px 30px;border-radius:26px;font-size:15px;font-family:'Inter',sans-serif;font-weight:600;cursor:pointer;transition:transform .2s,background .2s;position:relative;overflow:hidden}
.btn-p:hover{transform:translateY(-3px);background:var(--e-mid)}
.btn-wa{background:#25D366;color:#fff;border:none;padding:13px 24px;border-radius:26px;font-size:15px;font-family:'Inter',sans-serif;font-weight:600;cursor:pointer;transition:transform .2s;display:flex;align-items:center;gap:7px}
.btn-wa:hover{transform:translateY(-3px);background:#1da851}
.btn-s{background:transparent;color:#1a1a1a;border:1px solid rgba(1,143,84,0.3);padding:13px 26px;border-radius:26px;font-size:15px;font-family:'Inter',sans-serif;cursor:pointer;transition:transform .2s}
.btn-s:hover{transform:translateY(-3px);border-color:var(--e-base)}

.scroll-cue{margin-top:2.5rem;display:flex;flex-direction:column;align-items:center;gap:5px;color:#888;font-size:11px;letter-spacing:.12em;text-transform:uppercase;animation:fadeUp 0.6s 1.1s both}
.cue-line{width:1px;height:36px;background:linear-gradient(to bottom,rgba(1,143,84,.4),transparent);margin:4px auto 0}

/* CERT SHOWCASE */
.cert-showcase{background:#E8F0FE;border-top:1px solid #93a8f4;border-bottom:1px solid #93a8f4;padding:1.6rem 2rem;text-align:center}
.cert-card{display:inline-flex;align-items:center;gap:14px;background:#fff;border:1.5px solid #93a8f4;border-radius:16px;padding:1rem 2rem;box-shadow:0 4px 20px rgba(147,168,244,.15)}
.cert-seal{width:52px;height:52px;border-radius:50%;background:#E8F0FE;border:2px solid #93a8f4;display:flex;align-items:center;justify-content:center;color:#1a3a8f;font-size:24px;flex-shrink:0}
.cert-title{font-family:'Syne',sans-serif;font-size:16px;font-weight:800;color:#1a3a8f}
.cert-sub{font-size:13px;color:#3a5abf;margin-top:2px}

/* TRUST BAND */
.trust-band{background:var(--e-deep);padding:2.2rem 2rem;position:relative;overflow:hidden}
.trust-inner{position:relative;z-index:1;display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(1,143,84,0.25);border-radius:18px;overflow:hidden}
.trust-item{background:var(--e-deep);padding:1.5rem;text-align:center}
.trust-ico{font-size:26px;color:var(--e-bright);margin-bottom:8px;animation:floatY 4s ease-in-out infinite}
.trust-item:nth-child(2) .trust-ico{animation-delay:.5s}
.trust-item:nth-child(3) .trust-ico{animation-delay:1s}
.trust-item:nth-child(4) .trust-ico{animation-delay:1.5s}
.trust-val{font-family:'Syne',sans-serif;font-size:26px;font-weight:800;color:var(--e-pale)}
.trust-lbl{font-size:12px;color:var(--e-light);margin-top:3px}
.trust-orb{position:absolute;border-radius:50%;background:var(--e-dark);opacity:.5}
.to1{width:220px;height:220px;top:-90px;left:-70px}
.to2{width:160px;height:160px;bottom:-70px;right:-50px}

/* CHIPS */
.chips{display:flex;gap:14px;padding:1.6rem 2rem;justify-content:center;flex-wrap:wrap;background:var(--e-wash);border-bottom:1px solid rgba(1,143,84,0.12)}
.chip{background:#fff;border:1px solid rgba(1,143,84,0.18);border-radius:14px;padding:.9rem 1.1rem;display:flex;align-items:center;gap:10px;transition:transform .25s,box-shadow .25s}
.chip:hover{transform:translateY(-5px);box-shadow:0 8px 24px rgba(1,143,84,.1)}
.chip-ico{width:36px;height:36px;border-radius:10px;background:var(--e-wash);display:flex;align-items:center;justify-content:center;color:var(--e-base);font-size:18px;flex-shrink:0}
.chip-lbl{font-size:11px;color:#888}
.chip-val{font-size:13px;font-weight:600}

/* SECTIONS */
.section{padding:4rem 2rem}
.section-alt{padding:4rem 2rem;background:#f8faf9;border-top:1px solid rgba(1,143,84,0.08);border-bottom:1px solid rgba(1,143,84,0.08)}
.sec-inner{max-width:680px;margin:0 auto}
.eyebrow{font-size:11px;font-weight:700;color:var(--e-base);letter-spacing:.13em;text-transform:uppercase;margin-bottom:10px}
.sec-title{font-family:'Syne',sans-serif;font-size:30px;font-weight:800;margin-bottom:10px;letter-spacing:-0.02em}
.sec-sub{font-size:15px;color:#666;margin-bottom:2.2rem;line-height:1.7}

/* SERVICES */
.svc-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:14px}
.svc{background:#fff;border:1px solid rgba(1,143,84,0.18);border-radius:18px;padding:1.4rem;transition:transform .25s,border-color .25s,background .25s,box-shadow .25s}
.svc:hover{transform:translateY(-8px);border-color:var(--e-light);background:var(--e-wash);box-shadow:0 12px 36px rgba(1,143,84,.1)}
.svc-new{border-color:rgba(1,143,84,.5);background:var(--e-wash)}
.svc-new-tag{display:inline-block;font-size:10px;font-weight:700;background:var(--e-base);color:#fff;padding:2px 9px;border-radius:8px;margin-bottom:9px;letter-spacing:.05em}
.svc-ico{font-size:24px;color:var(--e-base);margin-bottom:12px}
.svc h3{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;margin-bottom:6px}
.svc p{font-size:12px;color:#666;line-height:1.6}

/* WHY */
.why-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:14px}
.why-card{border-radius:18px;padding:1.6rem;position:relative;overflow:hidden;transition:transform .25s}
.why-card:hover{transform:translateY(-6px)}
.why-dark{background:var(--e-deep)}
.why-light{background:var(--e-wash);border:1px solid rgba(1,143,84,0.18)}
.why-num{font-family:'Syne',sans-serif;font-size:44px;font-weight:800;opacity:.1;position:absolute;top:6px;right:14px;line-height:1}
.why-ico{font-size:26px;margin-bottom:12px}
.why-title{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;margin-bottom:6px}
.why-desc{font-size:12px;line-height:1.6}
.why-dark .why-num{color:var(--e-bright)}.why-dark .why-ico{color:var(--e-light)}.why-dark .why-title{color:var(--e-pale)}.why-dark .why-desc{color:var(--e-light)}
.why-light .why-num{color:var(--e-base)}.why-light .why-ico{color:var(--e-base)}.why-light .why-title{color:var(--e-dark)}.why-light .why-desc{color:var(--e-mid)}

/* BARS */
.bars-section{padding:4rem 2rem;background:var(--e-wash);border-top:1px solid rgba(1,143,84,.12);border-bottom:1px solid rgba(1,143,84,.12)}
.bar-row{margin-bottom:1.5rem}
.bar-top{display:flex;justify-content:space-between;font-size:14px;margin-bottom:8px}
.bpct{font-weight:700;color:var(--e-base)}
.bar-track{height:10px;background:rgba(1,143,84,0.12);border-radius:10px;overflow:hidden}
.bar-fill{height:100%;border-radius:10px;background:var(--e-base);width:0;transition:width 1.5s cubic-bezier(.4,0,.2,1)}

/* PORTFOLIO */
.port-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(190px,1fr));gap:14px}
.pcard{background:#fff;border:1px solid rgba(1,143,84,0.18);border-radius:18px;padding:1.4rem;transition:transform .25s,background .25s}
.pcard:hover{transform:translateY(-7px);background:var(--e-wash)}
.pcard-gold{background:var(--gold-light);border:2px solid var(--gold);border-radius:18px;padding:1.4rem;transition:transform .25s;position:relative;overflow:hidden}
.pcard-gold:hover{transform:translateY(-7px)}
.gold-orb{position:absolute;width:120px;height:120px;border-radius:50%;background:rgba(201,168,76,.12);top:-40px;right:-30px;animation:floatY 5s ease-in-out infinite}
.ptag{display:inline-block;font-size:11px;background:var(--e-wash);color:var(--e-dark);padding:4px 12px;border-radius:14px;margin-bottom:10px;font-weight:600}
.ptag-gold{display:inline-block;font-size:11px;background:var(--gold-light);color:var(--gold-dark);padding:4px 12px;border-radius:14px;margin-bottom:10px;font-weight:700;border:1px solid var(--gold)}
.pcard h3{font-family:'Syne',sans-serif;font-size:14px;font-weight:700;margin-bottom:5px}
.pcard-gold h3{font-family:'Syne',sans-serif;font-size:14px;font-weight:800;margin-bottom:5px;color:var(--gold-dark)}
.pcard p{font-size:12px;color:#666;line-height:1.5}
.pcard-gold p{font-size:12px;color:#7a5c10;line-height:1.5}
.pres{font-size:13px;font-weight:600;color:var(--e-mid);margin-top:12px;display:flex;align-items:center;gap:5px}
.pres-gold{font-size:13px;font-weight:700;color:var(--gold-dark);margin-top:12px;display:flex;align-items:center;gap:5px}
.pres-gold-big{font-family:'Syne',sans-serif;font-size:20px;font-weight:800;color:var(--gold-dark)}
.gold-badge{display:inline-flex;align-items:center;gap:4px;background:rgba(201,168,76,.18);color:var(--gold-dark);font-size:10px;font-weight:700;padding:3px 10px;border-radius:10px;margin-top:8px;border:1px solid rgba(201,168,76,.3);letter-spacing:.04em}

/* TESTIMONIALS */
.tgrid{display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:14px}
.tc{background:#fff;border:1px solid rgba(1,143,84,0.18);border-radius:18px;padding:1.4rem;transition:transform .25s}
.tc:hover{transform:translateY(-5px)}
.stars{color:#BA7517;font-size:14px;margin-bottom:10px}
.tc p{font-size:13px;color:#555;line-height:1.65;margin-bottom:14px;font-style:italic}
.tauthor{display:flex;align-items:center;gap:10px}
.av{width:36px;height:36px;border-radius:50%;background:var(--e-wash);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:var(--e-dark);flex-shrink:0}
.aname{font-size:13px;font-weight:700;font-family:'Syne',sans-serif}
.arole{font-size:11px;color:#888}

/* CTA BAND */
.cta-band{background:var(--e-deep);padding:5rem 2rem;text-align:center;position:relative;overflow:hidden}
.cta-orb{position:absolute;border-radius:50%;background:var(--e-dark);pointer-events:none}
.co1{width:340px;height:340px;top:-130px;left:-110px;opacity:.8;animation:floatY 9s ease-in-out infinite}
.co2{width:240px;height:240px;bottom:-100px;right:-80px;opacity:.6;animation:floatY 7s 2s ease-in-out infinite}
.cta-eyebrow{font-size:11px;font-weight:700;color:var(--e-light);letter-spacing:.14em;text-transform:uppercase;margin-bottom:12px;position:relative;z-index:1}
.cta-band h2{font-family:'Syne',sans-serif;font-size:36px;font-weight:800;color:var(--e-wash);margin-bottom:.6rem;position:relative;z-index:1;letter-spacing:-0.02em}
.cta-hook{font-family:'Syne',sans-serif;font-size:16px;font-weight:600;color:var(--e-bright);margin-bottom:1rem;position:relative;z-index:1}
.cta-band p{font-size:15px;color:var(--e-pale);margin-bottom:2.5rem;position:relative;z-index:1}
.cta-row{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;position:relative;z-index:1}
.cbp{background:var(--e-bright);color:var(--e-deep);border:none;padding:14px 32px;border-radius:28px;font-size:15px;font-family:'Inter',sans-serif;font-weight:700;cursor:pointer;transition:transform .2s}
.cbp:hover{transform:translateY(-3px)}
.cbwa{background:#25D366;color:#fff;border:none;padding:14px 26px;border-radius:28px;font-size:15px;font-family:'Inter',sans-serif;font-weight:700;cursor:pointer;transition:transform .2s;display:flex;align-items:center;gap:7px}
.cbwa:hover{transform:translateY(-3px)}

/* CONTACT */
.contact-bg{background:var(--e-wash);border-top:1px solid rgba(1,143,84,0.18);padding:5rem 2rem}
.cinner{max-width:500px;margin:0 auto;text-align:center}
.ccard{background:#fff;border:1px solid rgba(1,143,84,0.18);border-radius:20px;padding:2.2rem;text-align:left;margin-top:1.8rem}
.wa-block{background:#E8FBF0;border:1px solid rgba(37,211,102,0.3);border-radius:14px;padding:1.1rem;display:flex;align-items:center;gap:14px;margin-bottom:1.4rem;cursor:pointer;transition:transform .2s}
.wa-block:hover{transform:scale(1.02)}
.wa-ico{width:44px;height:44px;border-radius:12px;background:#25D366;display:flex;align-items:center;justify-content:center;color:#fff;font-size:22px;flex-shrink:0;animation:waBounce 2.5s ease-in-out infinite}
.wa-text{font-size:14px;font-weight:600;color:#014D2E}
.wa-sub{font-size:12px;color:#016B3F;margin-top:2px}
.fg{margin-bottom:1.1rem}
.fg label{display:block;font-size:12px;color:#666;margin-bottom:5px;font-weight:500}
.fg input,.fg textarea,.fg select{width:100%;border:1px solid rgba(1,143,84,0.22);border-radius:12px;padding:10px 14px;font-size:14px;background:#fff;color:#1a1a1a;transition:border-color .2s;font-family:'Inter',sans-serif}
.fg input:focus,.fg textarea:focus,.fg select:focus{outline:none;border-color:var(--e-base);box-shadow:0 0 0 3px rgba(1,143,84,.08)}
.fg textarea{height:85px;resize:vertical}
.sbtn{width:100%;background:var(--e-base);color:#fff;border:none;padding:13px;border-radius:28px;font-size:15px;font-weight:600;font-family:'Inter',sans-serif;cursor:pointer;margin-top:.6rem;transition:transform .2s,background .2s;display:flex;align-items:center;justify-content:center;gap:7px}
.sbtn:hover{transform:translateY(-2px);background:var(--e-mid)}

/* FOOTER */
footer{padding:1.6rem 2rem;border-top:1px solid rgba(1,143,84,.12);display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;font-size:13px;color:#888}
.footer-logo{font-family:'Syne',sans-serif;font-weight:800;font-size:16px;color:#1a1a1a}
.footer-cert{background:#E8F0FE;color:#1a3a8f;font-size:10px;font-weight:700;padding:4px 12px;border-radius:8px;border:1px solid #93a8f4}
.footer-tag{font-family:'Syne',sans-serif;font-weight:700;color:var(--e-base);font-size:13px}

/* WHATSAPP FLOAT */
.wa-float{position:fixed;bottom:24px;right:24px;z-index:9999;background:#25D366;color:#fff;border:none;width:56px;height:56px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:26px;cursor:pointer;box-shadow:0 6px 24px rgba(37,211,102,.5);animation:waBounce 3s 1s ease-in-out infinite}
.wa-float:hover{transform:scale(1.12)}
.wa-tip{position:fixed;bottom:30px;right:90px;background:var(--e-deep);color:var(--e-pale);border-radius:22px;padding:7px 16px;font-size:12px;font-weight:600;white-space:nowrap;pointer-events:none;animation:fadeLeft 0.5s 2s both;font-family:'Inter',sans-serif}
</style>
</head>
